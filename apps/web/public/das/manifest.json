{
  "manifest_version": 3,
  "name": "DAS — Clinical AI Scribe",
  "short_name": "DAS",
  "version": "1.1.0",
  "description": "Ambient AI medical documentation assistant. Record consultations, auto-generate SOAP notes, and inject into any EHR or web field.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "https://api.groq.com/*",
    "https://generativelanguage.googleapis.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DAS — Open Clinical Scribe"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["webapp/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
