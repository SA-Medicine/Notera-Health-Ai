{
  "name": "notera-health-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Notera-Health-Ai — production clinical documentation engine (Next.js + Node/Cloud Run + Python NER + Gemini + Firestore)",
  "type": "module",
  "workspaces": [
    "schema",
    "backend",
    "eval",
    "web"
  ],
  "scripts": {
    "dev:backend": "npm --workspace @notera/backend run dev",
    "start:backend": "npm --workspace @notera/backend run start",
    "test": "npm --workspace @notera/backend run test && npm --workspace @notera/eval run test",
    "eval": "npm --workspace @notera/eval run eval",
    "admin": "node admin/server.mjs",
    "db:migrate": "node db/migrate.mjs",
    "db:backfill": "node db/backfill_files.mjs",
    "db:backfill:firestore": "node db/backfill_firestore.mjs",
    "db:up": "docker compose -f db/docker-compose.postgres.yml up -d",
    "db:down": "docker compose -f db/docker-compose.postgres.yml down"
  },
  "engines": {
    "node": ">=20"
  }
}
