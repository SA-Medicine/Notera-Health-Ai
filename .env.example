# ── Notera-Health-Ai — environment (copy to .env; never commit real secrets) ──

# ── Generation (Gemini) — doc 06 ─────────────────────────────────────────────
# ai_studio = Google AI Studio API (de-identified input only, NOT BAA-covered)
# vertex    = Vertex AI (HIPAA-eligible under a BAA; PHI allowed)
LLM_BACKEND=ai_studio
GEMINI_API_KEY=your_ai_studio_key_here
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
# For Vertex:
GCP_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1

# ── NER sidecar (doc 07 §4) ──────────────────────────────────────────────────
NER_URL=http://localhost:8000
NER_USE_IAM=false            # true in prod (Cloud Run → Cloud Run ID token)

# ── Data layer (doc 09) ──────────────────────────────────────────────────────
FIRESTORE_DRIVER=memory      # memory (dev) | firestore (prod)

# ── Medical ASR (doc 08) ─────────────────────────────────────────────────────
ASR_MODEL=medical_conversation
ASR_LANGUAGE=en-US
ASR_SAMPLE_RATE=16000

# ── Backend service ──────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
REQUIRE_AUTH=false
SERVICE_TOKENS=dev-token     # comma-separated bearer tokens the web app presents (dev)
PIPELINE_VERSION=notera-pipeline-v31

# ── Frontend (web/) ──────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8080
BACKEND_SERVICE_TOKEN=dev-token

# ── PostgreSQL (data store) ───────────────────────────────────────────────────
STORE_BACKEND=postgres                                   # postgres | firestore | memory
DATABASE_URL=postgres://notera_admin:CHANGE_ME@localhost:5432/notera
PG_POOL_MAX=10
PGSSL=                                                    # 'require' to force TLS
DEID_ENC_KEY=CHANGE_ME_ENCRYPTION_KEY                     # pgcrypto key for the de-id map (keep in a KMS in prod)
